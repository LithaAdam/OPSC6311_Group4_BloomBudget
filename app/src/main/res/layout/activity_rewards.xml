<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".RewardsActivity">

    <ImageButton
        android:id="@+id/back_button"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/blue_accent" />

    <TextView
        android:id="@+id/title_rewards"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:text="@string/title_rewards"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/back_button"
        app:layout_constraintStart_toEndOf="@id/back_button"
        app:layout_constraintTop_toTopOf="@id/back_button" />

    <ImageButton
        android:id="@+id/more_options"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_more_vert"
        app:layout_constraintBottom_toBottomOf="@id/back_button"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/back_button"
        app:tint="@color/text_primary" />

    <androidx.cardview.widget.CardView
        android:id="@+id/points_card"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:layout_margin="16dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:layout_constraintTop_toBottomOf="@id/back_button">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/rewards_card_gradient"
            android:padding="24dp">

            <TextView
                android:id="@+id/label_your_points"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_your_points"
                android:textColor="@color/subtitle_gray"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/points_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/label_your_points"
                android:layout_marginTop="8dp"
                android:text="@string/placeholder_points"
                android:textColor="@color/text_primary"
                android:textSize="48sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/user_level"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignBottom="@id/points_value"
                android:layout_marginStart="8dp"
                android:layout_marginBottom="12dp"
                android:layout_toEndOf="@id/points_value"
                android:text="@string/format_level"
                android:textColor="@color/subtitle_gray"
                android:textSize="18sp" />

            <ProgressBar
                android:id="@+id/level_progress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:layout_below="@id/points_value"
                android:layout_marginTop="8dp"
                android:progress="30"
                android:progressTint="@color/progress_bar_rewards" />

            <TextView
                android:id="@+id/view_details"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentBottom="true"
                android:text="@string/label_view_details"
                android:textColor="@color/text_dark_blue"
                android:textSize="14sp"
                android:textStyle="bold" />

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_launcher_foreground"
                app:tint="@color/yellow" />
        </RelativeLayout>
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/label_achievements"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="24dp"
        android:text="@string/label_achievements"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/points_card" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        app:layout_constraintBottom_toTopOf="@id/bottom_navigation"
        app:layout_constraintTop_toBottomOf="@id/label_achievements">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Budget Master -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <View
                        android:id="@+id/achievement1_icon_bg"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/dot_pink"
                        android:backgroundTint="@color/icon_beige" />

                    <TextView
                        android:id="@+id/achievement1_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_toEndOf="@id/achievement1_icon_bg"
                        android:text="@string/title_budget_master"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/achievement1_title"
                        android:layout_marginStart="16dp"
                        android:layout_toEndOf="@id/achievement1_icon_bg"
                        android:text="@string/desc_budget_master"
                        android:textColor="@color/subtitle_gray"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/status_budget_master"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:text="@string/label_locked"
                        android:textColor="@color/red" />
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <!-- 7 Day Streak Saver -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <View
                        android:id="@+id/achievement2_icon_bg"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/dot_pink"
                        android:backgroundTint="@color/icon_pink" />

                    <TextView
                        android:id="@+id/achievement2_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_toEndOf="@id/achievement2_icon_bg"
                        android:text="@string/title_streak_saver"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/achievement2_title"
                        android:layout_marginStart="16dp"
                        android:layout_toEndOf="@id/achievement2_icon_bg"
                        android:text="@string/desc_streak_saver"
                        android:textColor="@color/subtitle_gray"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/status_streak_saver"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:text="@string/label_locked"
                        android:textColor="@color/red" />
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <!-- Expense Tax deduction -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <View
                        android:id="@+id/achievement3_icon_bg"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/dot_pink"
                        android:backgroundTint="@color/icon_blue" />

                    <TextView
                        android:id="@+id/achievement3_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_toEndOf="@id/achievement3_icon_bg"
                        android:text="@string/title_tax_deduction"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/achievement3_title"
                        android:layout_marginStart="16dp"
                        android:layout_toEndOf="@id/achievement3_icon_bg"
                        android:text="@string/desc_tax_deduction"
                        android:textColor="@color/subtitle_gray"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/status_tax_deduction"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:text="@string/label_locked"
                        android:textColor="@color/red" />
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/background"
        app:layout_constraintBottom_toBottomOf="parent"
        app:menu="@menu/bottom_nav_menu" />

</androidx.constraintlayout.widget.ConstraintLayout>